#!/usr/bin/env bash
set -euo pipefail

src="${BASH_SOURCE[0]}"
while [ -L "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  case "$src" in /*) ;; *) src="$dir/$src" ;; esac
done
LIB="$(cd -P "$(dirname "$src")/../lib" && pwd)"
# Absolute path to this resolved entrypoint — used by `fs autostart` for the
# launchd ProgramArguments (must be a stable, absolute path).
FS_SELF="$(cd -P "$(dirname "$src")" && pwd)/$(basename "$src")"; export FS_SELF
# shellcheck source=/dev/null
for f in helpers deps caddy process commands dashboard; do
  [ -f "$LIB/$f.sh" ] && . "$LIB/$f.sh"
done

fs_usage() {
  cat <<'EOF'
Usage: fs <command> [args]

  setup             One-time machine setup (dnsmasq, caddy, cert, deps)
  serve             Zero-config: default PHP config, serve, and open in the browser
  init              Create a .folderserver config in the current folder
  up [--all]        Start serving the current folder (or every known site)
  down [--all]      Stop serving the current folder (or every running site)
  restart [--all]   Restart the current folder (or every known site)
  edit              Edit the current folder's config (php, routing, MySQL)
  unbind [--all]    Stop, delete .folderserver, and forget the current folder (or all)
  list              List all known sites and their status
  open              Open the current folder's URL in the browser
  logs              Tail the current folder's PHP log
  db start|stop|status   Control the shared MySQL service
  dash              Live TUI dashboard
  autostart on|off|status  Start all sites at login (launchd)
  help              Show this help
EOF
}

main() {
  local cmd="${1:-}"
  [ -n "$cmd" ] || { fs_usage; return 2; }
  shift || true
  case "$cmd" in
    help|-h|--help) fs_usage ;;
    version|-v|--version) echo "folder-server 1.0.0" ;;
    setup)   fs_cmd_setup "$@" ;;
    serve)   fs_cmd_serve "$@" ;;
    init)    fs_cmd_init "$@" ;;
    up)      fs_cmd_up "$@" ;;
    down)    fs_cmd_down "$@" ;;
    restart) fs_cmd_restart "$@" ;;
    edit)    fs_cmd_edit "$@" ;;
    unbind)  fs_cmd_unbind "$@" ;;
    list)    fs_cmd_list "$@" ;;
    open)    fs_cmd_open "$@" ;;
    logs)    fs_cmd_logs "$@" ;;
    db)      fs_cmd_db "$@" ;;
    dash)    fs_cmd_dash "$@" ;;
    autostart) fs_cmd_autostart "$@" ;;
    *) echo "fs: unknown command: $cmd" >&2; fs_usage >&2; return 127 ;;
  esac
}
main "$@"
