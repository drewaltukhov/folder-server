<?php
// Auto-generated by folder-server. Router for `php -S`.
//
// Two jobs:
//   1. Run *.html / *.htm files through the PHP interpreter, so pages with an
//      .html extension can still contain embedded PHP tags. The built-in
//      server only executes .php files and serves every other extension
//      static; a router is the only way to change that.
//   2. Optional front controller: route otherwise-unmatched URLs to a single
//      entry script — the classic .htaccess "send unknown URLs to index.php"
//      rewrite used by WordPress, Laravel, etc. Empty when no rewrite is set.
$root = rtrim($_SERVER['DOCUMENT_ROOT'], '/');
$path = urldecode(parse_url($_SERVER['REQUEST_URI'], PHP_URL_PATH));
$fc   = '{{FRONT_CONTROLLER}}';

// Never resolve a path outside the docroot.
if (strpos($path, '..') !== false) { return false; }

$file = $root . $path;

// Directory request: resolve an index file ourselves so index.html is parsed
// as PHP too (php -S would serve it static). index.php wins when both exist.
if ($path === '' || substr($path, -1) === '/') {
    foreach (['index.php', 'index.html', 'index.htm'] as $idx) {
        if (is_file($file . $idx)) { require $file . $idx; return true; }
    }
}
// A real *.html / *.htm file → run it through the interpreter.
elseif (preg_match('/\.html?$/i', $path) && is_file($file)) {
    require $file;
    return true;
}
// Any other existing file → let php -S serve it as-is (static asset).
elseif (is_file($file)) {
    return false;
}

// Unmatched URL: hand to the front controller when one is configured.
if ($fc !== '' && is_file($root . '/' . $fc)) {
    require $root . '/' . $fc;
    return true;
}
return false;
